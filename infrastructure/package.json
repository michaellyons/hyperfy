{
  "name": "mcmaster-museum-infrastructure",
  "version": "1.0.0",
  "description": "AWS CDK infrastructure for McMaster Museum — multi-world Hyperfy deployment",
  "private": true,
  "scripts": {
    "build":   "tsc",
    "watch":   "tsc -w",
