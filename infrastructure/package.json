    "destroy": "cdk destroy --all"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.170.0",
    "constructs":  "^10.4.2"
  },
  "devDependencies": {
    "aws-cdk":         "^2.170.0",
    "typescript":      "^5.3.0",
    "@types/node":     "^20.0.0"
  }
}
